{
  "$schema": "https://irodori.dev/schemas/irodori.extension.schema.json",
  "manifestVersion": 1,
  "id": "irodori.redis",
  "name": "Redis Connector",
  "version": "0.1.0",
  "publisher": "irodori",
  "description": "Redis Connector contributes the Redis database connector through the native connector ABI.",
  "license": "MIT OR 0BSD",
  "repository": "https://github.com/hjosugi/irodori-extension-redis",
  "apiVersion": "0.1",
  "runtime": "native",
  "entry": "dist/native",
  "permissions": [
    "connections:read",
    "connections:write",
    "queries:run",
    "metadata:read",
    "native",
    "connectors"
  ],
  "contributes": {
    "connectors": [
      {
        "id": "redis.connector",
        "engine": "redis",
        "label": "Redis",
        "aliases": [
          "redis",
          "Redis"
        ],
        "defaultPort": 6379,
        "wire": "redis",
        "module": "redis.driver",
        "features": [
          "metadata",
          "streaming"
        ],
        "connection": {
          "schemaVersion": 1,
          "inferEnvironmentFrom": [
            "name",
            "id",
            "host",
            "database",
            "url"
          ],
          "compatibility": {
            "addsRequiredProfileFields": false,
            "acceptsExistingProfiles": true
          },
          "defaults": {
            "engine": "redis",
            "wire": "redis",
            "port": 6379,
            "readOnly": false
          },
          "endpoint": {
            "modes": [
              "hostPort",
              "connectionString"
            ],
            "defaultPort": 6379,
            "fields": [
              {
                "id": "host",
                "label": "Host",
                "type": "string",
                "profileField": "host",
                "required": true
              },
              {
                "id": "port",
                "label": "Port",
                "type": "number",
                "profileField": "port",
                "default": 6379
              },
              {
                "id": "database",
                "label": "Database index",
                "type": "string",
                "profileField": "database"
              }
            ]
          },
          "profileFields": [
            {
              "id": "id",
              "label": "Connection ID",
              "type": "string",
              "profileField": "id",
              "required": true
            },
            {
              "id": "url",
              "label": "Connection URL or DSN",
              "type": "uri",
              "profileField": "url"
            },
            {
              "id": "user",
              "label": "User",
              "type": "string",
              "profileField": "user"
            },
            {
              "id": "host",
              "label": "Host",
              "type": "string",
              "profileField": "host",
              "required": true
            },
            {
              "id": "port",
              "label": "Port",
              "type": "number",
              "profileField": "port",
              "default": 6379
            },
            {
              "id": "database",
              "label": "Database index",
              "type": "string",
              "profileField": "database"
            },
            {
              "id": "readOnly",
              "label": "Read-only connection",
              "type": "boolean",
              "profileField": "readOnly",
              "default": false
            },
            {
              "id": "options",
              "label": "Driver options",
              "type": "map",
              "profileField": "options"
            }
          ],
          "authMethods": [
            {
              "id": "none",
              "label": "No authentication",
              "kind": "none",
              "secretPurposes": [],
              "fields": []
            },
            {
              "id": "connectionString",
              "label": "Connection string / DSN",
              "kind": "connectionString",
              "secretPurposes": [],
              "fields": [
                {
                  "id": "url",
                  "label": "Connection URL or DSN",
                  "type": "uri",
                  "profileField": "url",
                  "required": true
                }
              ]
            },
            {
              "id": "aclUserPassword",
              "label": "ACL user/password",
              "kind": "userPassword",
              "secretPurposes": [
                "password"
              ],
              "fields": [
                {
                  "id": "user",
                  "label": "User",
                  "type": "string",
                  "profileField": "user"
                },
                {
                  "id": "password",
                  "label": "Password",
                  "type": "secret",
                  "secretPurpose": "password",
                  "profileField": "password"
                }
              ]
            },
            {
              "id": "redisToken",
              "label": "Token",
              "kind": "token",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "token",
                  "label": "Token",
                  "type": "secret",
                  "secretPurpose": "token"
                }
              ]
            },
            {
              "id": "clientCertificate",
              "label": "Client certificate / mTLS",
              "kind": "certificate",
              "secretPurposes": [
                "privateKey",
                "privateKeyPassphrase"
              ],
              "fields": [
                {
                  "id": "clientCertificate",
                  "label": "Client certificate",
                  "type": "pem"
                },
                {
                  "id": "clientPrivateKey",
                  "label": "Client private key",
                  "type": "pem",
                  "secretPurpose": "privateKey"
                },
                {
                  "id": "clientPrivateKeyPassphrase",
                  "label": "Private key passphrase",
                  "type": "secret",
                  "secretPurpose": "privateKeyPassphrase"
                }
              ]
            },
            {
              "id": "customDriverOptions",
              "label": "Custom driver options",
              "kind": "custom",
              "secretPurposes": [
                "password",
                "token",
                "privateKey",
                "privateKeyPassphrase"
              ],
              "fields": [
                {
                  "id": "options",
                  "label": "Driver options",
                  "type": "map",
                  "profileField": "options"
                }
              ]
            }
          ],
          "secretPurposes": [
            "password",
            "token",
            "privateKey",
            "privateKeyPassphrase"
          ],
          "tls": {
            "supported": true,
            "requiredByDefault": false,
            "modes": [
              "disable",
              "prefer",
              "require",
              "verifyCa",
              "verifyFull",
              "clientCertificate"
            ],
            "fields": [
              {
                "id": "caCertificate",
                "label": "CA certificate",
                "type": "pem"
              },
              {
                "id": "clientCertificate",
                "label": "Client certificate",
                "type": "pem"
              },
              {
                "id": "clientPrivateKey",
                "label": "Client private key",
                "type": "pem",
                "secretPurpose": "privateKey"
              }
            ]
          },
          "transports": [
            "direct",
            "sshTunnel",
            "socks5Proxy",
            "httpConnectProxy",
            "proxyChain"
          ],
          "optionNamespaces": [
            "profile.options",
            "driver",
            "tls",
            "network",
            "redis"
          ],
          "customDriverOptions": true
        }
      }
    ]
  },
  "capabilities": {
    "nativeModules": [
      {
        "id": "redis.driver",
        "path": "dist/native",
        "platforms": [
          "windowsX64",
          "windowsArm64",
          "macosX64",
          "macosArm64",
          "linuxX64",
          "linuxArm64"
        ]
      }
    ]
  },
  "dev": {
    "watch": [
      "src",
      "connector.config.json",
      "irodori.extension.json"
    ]
  }
}
